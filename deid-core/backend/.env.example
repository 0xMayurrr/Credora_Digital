PORT=5000
MONGODB_URI=mongodb://localhost:27017/credora
NODE_ENV=development

JWT_SECRET=your_jwt_secret_key_change_me_minimum_32_chars
JWT_EXPIRES_IN=24h

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (NO trailing slashes)
# Production example: https://credora-veripass.netlify.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Hyperledger Fabric Config ────────────────────────────────────────────────
BLOCKCHAIN_TYPE=fabric
FABRIC_CHANNEL_NAME=credora-main-channel
CC_LIFECYCLE_NAME=certificate-lifecycle-cc
CC_CREDENTIAL_NAME=credential-registry-cc
CC_REVOCATION_NAME=revocation-registry-cc
CC_IDENTITY_NAME=identity-management-cc

# ── Pinata (IPFS Document Storage) ───────────────────────────────────────────
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key
PINATA_JWT=your_pinata_jwt_here

# ── Legacy Ethereum (only needed if BLOCKCHAIN_TYPE=ethereum) ─────────────────
# BLOCKCHAIN_NETWORK=amoy
# BLOCKCHAIN_RPC_URL=https://rpc-amoy.polygon.technology
# CONTRACT_ADDRESS=your_deployed_contract_address
# SERVER_WALLET_PRIVATE_KEY=your_server_wallet_private_key
